# Nokia Lumia 520 / Fame APPSBL payload loaded from the stock UEFI slot.
CONFIG_POSITION_INDEPENDENT=y
# CONFIG_SYS_ICACHE_OFF is not set
CONFIG_TEXT_BASE=0x88F00000
CONFIG_NR_DRAM_BANKS=2
CONFIG_DEFAULT_DEVICE_TREE="qcom/qcom-msm8227-nokia-fame"
CONFIG_SYS_BOOTM_LEN=0x04000000

CONFIG_DEBUG_UART=y
CONFIG_DEBUG_UART_MSM=y
CONFIG_DEBUG_UART_BASE=0x16440000
CONFIG_DEBUG_UART_CLOCK=1843200
CONFIG_DEBUG_UART_ANNOUNCE=y

CONFIG_ANDROID_BOOT_IMAGE=y
# CONFIG_BOOTSTD_FULL is not set
# CONFIG_BOOTSTD_DEFAULTS is not set
CONFIG_OF_BOARD_SETUP=y
CONFIG_FDT_SIMPLEFB=y
CONFIG_CONSOLE_RECORD=y
CONFIG_CONSOLE_RECORD_OUT_SIZE=0x100000
# CONFIG_EFI_LOADER is not set
# CONFIG_CMD_ELF is not set
CONFIG_CMD_XIMG=y
# CONFIG_CMD_EXPORTENV is not set
# CONFIG_CMD_IMPORTENV is not set
# CONFIG_CMD_EDITENV is not set
# CONFIG_CMD_SAVEENV is not set
# CONFIG_CMD_ENV_EXISTS is not set
CONFIG_CMD_ADTIMG=y
CONFIG_CMD_ABOOTIMG=y
CONFIG_CMD_FAME_MDP=y
CONFIG_CMD_REGULATOR=y
CONFIG_CMD_LOADB=y
# CONFIG_CMD_ITEST is not set
CONFIG_CMD_LSBLK=y
CONFIG_CMD_READ=y
CONFIG_CMD_SLEEP=y

# CONFIG_OF_UPSTREAM_BUILD_VENDOR is not set
CONFIG_ENV_DEFAULT_ENV_TEXT_FILE="board/qualcomm/fame.env"

CONFIG_VIDEO_QCOM_MDP4=y
CONFIG_VIDEO_QCOM_MDP4_FAME_AUTOSTART=y
# CONFIG_NO_FB_CLEAR is not set
# CONFIG_VIDEO_SIMPLE is not set

CONFIG_FASTBOOT_FLASH_BLOCK=y
CONFIG_FASTBOOT_FLASH_BLOCK_INTERFACE_NAME="mmc"
CONFIG_FASTBOOT_FLASH_BLOCK_DEVICE_ID=0
CONFIG_FASTBOOT_FETCH=y
CONFIG_FASTBOOT_OEM_RUN=y
CONFIG_FASTBOOT_CMD_OEM_CONSOLE=y
CONFIG_FASTBOOT_CMD_LOGICAL_PARTITIONS=y
CONFIG_FASTBOOT_BUF_ADDR=0x82000000
CONFIG_FASTBOOT_BUF_SIZE=0x04000000

CONFIG_ARM_PL180_MMCI=y
# CONFIG_MMC_HW_PARTITIONING is not set
CONFIG_USB_ULPI_VIEWPORT=y
CONFIG_USB_GADGET_MANUFACTURER="Nokia"
CONFIG_USB_GADGET_VENDOR_NUM=0x18D1
CONFIG_USB_GADGET_PRODUCT_NUM=0x4EE0
