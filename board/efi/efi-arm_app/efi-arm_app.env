bootdelay=0
stdin=serial
stdout=serial
stderr=serial

loadaddr=0x82000000
fastboot_addr_r=0x82000000
fastboot_size=0x02000000
fdt_addr_r=0x81f00000
fdtfile=qcom-msm8227-nokia-fame.dtb

load_fdt=fatload efi 0:EFIESP $fdt_addr_r /$fdtfile || fatload efi 0:21 $fdt_addr_r /$fdtfile
fastboot_bootcmd=run load_fdt && bootz $fastboot_addr_r - $fdt_addr_r
fastboot=fastboot -l $fastboot_addr_r -s $fastboot_size usb 0
ums_efiesp=echo Exporting EFIESP over USB mass storage; ums 0 efi 0:EFIESP || ums 0 efi 0:21

bootcmd=run fastboot; run menucmd
menucmd=bootmenu -1
bootmenu_0=Enable fastboot mode=run fastboot
bootmenu_1=Export EFIESP over USB mass storage=run ums_efiesp
bootmenu_2=Load Fame DTB=run load_fdt; pause
bootmenu_3=Dump USB registers=md.l 0x12500000 0x80; pause
bootmenu_4=Dump environment=printenv; pause
bootmenu_5=Drop to shell=setenv bootretry -1
bootmenu_6=Reset device=reset
