stdin=serial,button-kbd
stdout=serial,vidconsole
stderr=serial,vidconsole

blkmapcmd=blkmap create root;
	  blkmap map root 0 ${blkmap_size_r} linear ${blkmap_blk_ifname} ${blkmap_blk_dev} ${blkmap_blk_nr}

preboot=run blkmapcmd
prefastbootcmd=true

linux_kernel_addr_r=0xb5e00000
linux_ramdisk_addr_r=0xb5000000
linux_fdt_addr_r=0xb4f00000
linux_mmc_bootargs=console=tty0 console=ttySAC2,115200n8 earlycon keep_bootcon ignore_loglevel loglevel=8 initcall_debug panic=1 oops=panic printk.always_kmsg_dump=1 clk_ignore_unused pd_ignore_unused
userdata_boot=setenv bootargs ${linux_mmc_bootargs};
    if ext4load blkmap 0 ${linux_kernel_addr_r} /boot/Image &&
       ext4load blkmap 0 ${linux_ramdisk_addr_r} /boot/initrd.gz &&
       setenv ramdisk_size ${filesize} &&
       ext4load blkmap 0 ${linux_fdt_addr_r} /boot/exynos7870-j7xelte.dtb &&
       fdt addr ${linux_fdt_addr_r} &&
       fdt resize 0x1000;
    then
        fdt set /reserved-memory/ramoops@46e00000 record-size <0x4000>;
        fdt rm /reserved-memory/ramoops@46e00000 pmsg-size;
        booti ${linux_kernel_addr_r} ${linux_ramdisk_addr_r}:${ramdisk_size} ${linux_fdt_addr_r};
    fi

bootdelay=2
#ifdef CONFIG_EXYNOS_MOBILE_FASTBOOT_DEV
bootcmd=run fastbootcmd; bootmenu
#else
bootcmd=bootefi bootmgr; bootmenu
#endif

fastbootcmd=echo "Fastboot Mode - waiting for host; press Ctrl+C to exit";
	run prefastbootcmd && fastboot -l $fastboot_addr_r usb 0

bootmenu_0=Continue Boot=boot
bootmenu_1=Enter Fastboot Mode=run fastbootcmd
bootmenu_2=UEFI Maintenance Menu=eficonfig
bootmenu_3=Reboot=reset
bootmenu_4=Power Off=poweroff
bootmenu_5=Boot USERDATA Linux=run userdata_boot

button_cmd_0_name=Volume Down Key
button_cmd_0=bootmenu
