#include <config.h>

#ifdef CONFIG_BINMAN
#include <dt-bindings/arm/qcom,ids.h>

/ {
	binman: binman {
		multiple-images;

		u-boot-samsung-a5u-eur {
			filename = "u-boot-samsung-a5u-eur.img";

			android-boot {
				header-version = <0>;
				page-size = <2048>;
				base = <0x80000000>;
				append-seandroid-enforce;

				kernel {
					u-boot {
						no-expanded;
					};
				};

				ramdisk {
					fill {
						size = <1>;
					};
				};

				vendor-dt {
					qcdt {
						dtb-0 {
							#address-cells = <2>;
							#size-cells = <2>;
							compatible = "samsung,a5u-eur", "qcom,msm8916";
							qcom,msm-id = <QCOM_ID_MSM8916 0>;
							qcom,board-id = <0xce08ff01 1>;

							chosen {};
							memory@80000000 {
								device_type = "memory";
								reg = <0 0x80000000 0 0>;
							};
						};
					};
				};
			};
		};
	};
};
#endif
